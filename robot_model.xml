                      <site name="tcp_x" pos="0.060 0 0" size="0.004 0.060" euler="0 1.5708 0" rgba="1 0 0 0" type="cylinder"/>
                      <site name="tcp_y" pos="0 0.060 0" size="0.004 0.060" euler="1.5708 0 0" rgba="0 1 0 0" type="cylinder"/>

<?xml version="1.0" encoding="utf-8"?>
<!--
  scene.xml - Franka Panda pipe-flange inspection scene.

  This version intentionally does not use the provided DH parameters.
  The robot is the Franka Panda model from franka_sim-master, with mesh paths
  corrected for this workspace and a TCP-mounted inspection camera added.
-->
<mujoco model="franka_flange_inspection">
  <compiler angle="radian" autolimits="true"/>
  <option gravity="0 0 -9.81" timestep="0.002" integrator="RK4"/>
  <size nuser_actuator="5"/>
  <statistic extent="1"/>
  <visual>
    <!-- Wide clipping for the interactive world viewer.
         D405 depth rendering overrides this in Python to 0.07 m ~ 0.50 m. -->
    <global offwidth="1280" offheight="800"/>
    <map znear="0.01" zfar="5.00"/>
  </visual>

  <asset>
    <texture name="grid_floor" type="2d" builtin="checker"
             rgb1="0.72 0.72 0.72" rgb2="0.48 0.48 0.48" width="512" height="512"/>
    <material name="floor_mat" texture="grid_floor" texrepeat="8 8" reflectance="0.1"/>
    <texture name="skybox" type="skybox" builtin="gradient"
             rgb1="0.70 0.78 0.90" rgb2="0.20 0.30 0.50" width="512" height="512"/>

    <mesh name="link0_col" file="franka_sim-master/meshes/collision/link0.stl"/>

    <site size="0.008" rgba="1 1 0 1" type="sphere"/>
    <default class="panda">
      <joint pos="0 0 0" axis="0 0 1" limited="true"/>
      <position forcelimited="true" ctrllimited="true" user="1002 40 2001 -0.005 0.005"/>

                      <camera name="d405_camera" pos="0 0 -0.100" euler="3.14159 0 0" fovy="58" mode="fixed"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

